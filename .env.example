POSTMAN_API_KEY=PMAK-your-postman-api-key
POSTMAN_COLLECTION_ID=your-collection-id
POSTMAN_TARGET_NAME=Primary
# Add any number of targets. Numbered targets reuse POSTMAN_API_KEY unless
# POSTMAN_API_KEY_N is set for a different Postman account.
# POSTMAN_COLLECTION_ID_1=your-staging-collection-id
# POSTMAN_TARGET_NAME_1=Staging
# POSTMAN_API_KEY_8=PMAK-another-postman-api-key
# POSTMAN_COLLECTION_ID_8=your-production-collection-id
# POSTMAN_TARGET_NAME_8=Production
POSTMAN_COLLECTION_NAME=Procyon Generated API
POSTMAN_COLLECTION_FILE=docs/json/PostmanCollection.generated.json
POSTMAN_BASE_URL=https://api-dev.example.com
POSTMAN_ADMIN_URL=https://admin-dev.example.com
POSTMAN_UPLOAD_URL=https://upload-dev.example.com
POSTMAN_ADMIN_KEY=CHANGE_ME_ADMIN_KEY
POSTMAN_AUTH_KEY=
