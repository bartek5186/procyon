{
  "prod": false,
  "app_name": "Procyon",
  "server": {
    "host": "0.0.0.0",
    "port": 8081
  },
  "auth_domain": "http://127.0.0.1:4433",
  "auth": {
    "enabled": true,
    "provider": "kratos",
    "domain": "http://127.0.0.1:4433"
  },
  "rbac": {
    "enabled": true
  },
  "languages": ["pl", "en"],
  "domains": [
    "http://localhost:8081",
    "http://127.0.0.1:8081"
  ],
  "admin": {
    "enabled": true,
    "secret_key": "CHANGE_ME_ADMIN_KEY"
  },
  "observability": {
    "service_name": "procyon",
    "service_version": "dev",
    "environment": "dev",
    "namespace": "procyon",
    "metrics_path": "/metrics",
    "health_path": "/healthz",
    "ready_path": "/readyz",
    "info_path": "/info",
    "trace_sample_ratio": 1,
    "trace_exporter": "log",
    "trace_otlp_endpoint": "tempo:4317",
    "trace_otlp_insecure": true,
    "trace_otlp_headers": {},
    "trace_otlp_timeout_seconds": 10
  },
  "logging": {
    "level": "info",
    "file_enabled": false,
    "file_dir": "log"
  },
  "database": {
    "driver": "mysql",
    "host": "127.0.0.1",
    "user": "root",
    "password": "root",
    "dbname": "procyon",
    "port": 3306,
    "charset": "utf8mb4",
    "timezone": "UTC",
    "max_open_conns": 25,
    "max_idle_conns": 10,
    "conn_max_lifetime_seconds": 1800,
    "conn_max_idle_time_seconds": 300,
    "migrations_dir": "migrations/mysql",
    "migrations_table": "schema_migrations",
    "disable_versioned_migrations": false
  }
}
