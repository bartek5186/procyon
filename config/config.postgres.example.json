{
  "prod": false,
  "app_name": "Procyon",
  "servers": [
    {"name": "public", "host": "0.0.0.0",   "port": 8080},
    {"name": "admin",  "host": "127.0.0.1", "port": 8081},
    {"name": "upload", "host": "0.0.0.0",   "port": 8082}
  ],
  "auth_domain": "http://127.0.0.1:4433",
  "auth": {
    "provider": "kratos",
    "domain": "http://127.0.0.1:4433"
  },
  "rbac": {
    "default_role": "user",
    "admin_identity_ids": []
  },
  "languages": ["pl", "en"],
  "domains": [
    "http://localhost:8081",
    "http://127.0.0.1:8081"
  ],
  "admin": {
    "secret_key": "CHANGE_ME_ADMIN_KEY"
  },
  "observability": {
    "service_name": "procyon",
    "service_version": "dev",
    "environment": "dev",
    "namespace": "procyon",
    "metrics_path": "/metrics",
    "health_path": "/healthz",
    "ready_path": "/readyz",
    "info_path": "/info",
    "trace_sample_ratio": 1,
    "trace_exporter": "log",
    "metrics_exporter": "none",
    "trace_otlp_endpoint": "tempo:4317",
    "trace_otlp_insecure": true,
    "trace_otlp_headers": {},
    "trace_otlp_timeout_seconds": 10
  },
  "logging": {
    "level": "info",
    "file_enabled": false,
    "file_dir": "log"
  },
  "database": {
    "driver": "postgres",
    "host": "127.0.0.1",
    "user": "postgres",
    "password": "postgres",
    "dbname": "procyon",
    "port": 5432,
    "sslmode": "disable",
    "timezone": "UTC",
    "max_open_conns": 25,
    "max_idle_conns": 10,
    "conn_max_lifetime_seconds": 1800,
    "conn_max_idle_time_seconds": 300,
    "auto_migrate": true,
    "migrations_dir": "migrations/postgres",
    "migrations_table": "schema_migrations"
  }
}
